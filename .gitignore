# Ignore all python script files as all execution is consolidated into the master Jupyter notebook
*.py
*.py[cod]
*$py.class

# Byte-compiled / optimized / DLL files
__pycache__/

# Caching
.cache/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Antigravity CLI and temporary directories
.antigravitycli/
.tempmediaStorage/
.gemini/

# Large generated files and packaging archives
*.zip
*.rar
